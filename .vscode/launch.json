{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "args": [
                "-e",
                "devl"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceRoot}\test\functional-test.py",
            "args": [
                "-e",
                "devl"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}