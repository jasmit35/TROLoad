{
    "black-formatter.args": [
        "--line-length",
        "120",
    ],
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit"
    },
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "files.trimTrailingWhitespace": true,
    "flake8.args": [
        "--max-line-length",
        "120",
        "--extend-ignore",
        "E402"
    ],
    "python.analysis.extraPaths": [
        "/Users/jeff/.pyenv/versions/troload/lib/python3.12/site-packages",
        "/Users/jeff/devl/local/python",
        "/Users/jeff/devl/tro/local/python",
        "/Users/jeff/devl/troload/python",
    ],
    "python.autoComplete.extraPaths": [
        "/Users/jeff/devl/local/python",
        "/Users/jeff/devl/tro/local/python",
        "/Users/jeff/devl/troload/python",
    ],
    "python.pythonPath": "/Users/jeff/.pyenv/versions/troload/bin/python",
    "python.testing.unittestArgs": [
        "-v",
        "-s",
        "./tests",
        "-p",
        "test_*.py"
    ],
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true,
}
